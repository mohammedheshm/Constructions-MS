<odoo>
    <record id="site_view_tree" model="ir.ui.view">
        <field name="name">site.tree</field>
        <field name="model">construction.site</field>
        <field name="arch" type="xml">
            <tree>
                <field name="site_name"/>
                <field name="site_code"/>
                <field name="project_id"/>
                <field name="location"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration"/>
                <field name="state"/>
            </tree>
        </field>
    </record>


    <record id="site_view_form" model="ir.ui.view">
        <field name="name">site.form</field>
        <field name="model">construction.site</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_draft"
                            type="object"
                            class="btn-primary"
                            string="Set To Draft"
                            invisible="state in ('draft','closed')"/>

                    <button name="action_in_progress"
                            type="object"
                            class="btn-secondary"
                            string="Set To In Progress"
                            invisible="state != 'draft'"/>

                    <button name="action_done"
                            type="object"
                            class="btn-success"
                            string="Set To Done"
                            invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar"/>

                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="site_code"/>
                        <h1>
                            <field name="site_code"/>
                        </h1>

                        <label for="site_name"/>
                        <h3>
                            <field name="site_name"/>
                        </h3>
                    </div>
                    <group string="Site Information">
                        <field name="location"/>
                        <field name="project_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="duration"/>
                        <field name="expense_ids" widget="many2many_tags"/>
                    </group>

                    <group string="Workforce Info">
                        <field name="workforce_count"/>
                        <field name="workforce_ids" widget="many2many_tags"/>

                    </group>
                    <notebook>
                        <page string="Materials">
                            <field name="material_ids">
                                <tree editable="bottom">
                                    <field name="material_name"/>
                                    <field name="date"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="total_price"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Expenses">
                            <field name="expense_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="expense_date"/>
                                    <field name="expense_type"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_material_cost" readonly="1"/>
                                <field name="total_expense" readonly="1"/>
                                <field name="total_site_cost" readonly="1"/>

                            </group>
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="site_view_search" model="ir.ui.view">
        <field name="name">sites search</field>
        <field name="model">construction.site</field>
        <field name="arch" type="xml">
            <search>
                <field name="site_name"/>
                <field name="site_code"/>
                <field name="location"/>

                <filter name="state_draft"
                        string="Draft State"
                        domain="[('state','=','draft')]"/>

                <filter name="state_done"
                        string="Done State"
                        domain="[('state','=','done')]"/>

                <filter name="state_in_progress"
                        string="In Progress State"
                        domain="[('state','=','in_progress')]"/>


                <filter name="group_state"
                        string="Group By State"
                        context="{'group_by':'state'}"/>

                <filter name="group_start_date"
                        string="Group By Start Date"
                        context="{'group_by':'start_date'}"/>

            </search>
        </field>
    </record>


    <record id="site_closed_server_action" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_construction_site"/>
        <field name="binding_model_id" ref="model_construction_site"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_close()
        </field>
    </record>

    <record id="site_cron" model="ir.cron">
        <field name="name">Update Site Status</field>
        <field name="model_id" ref="model_construction_site"/>
        <field name="state">code</field>
        <field name="code">model.check_site_status()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>


    <record id="site_action" model="ir.actions.act_window">
        <field name="name">Sites</field>
        <field name="res_model">construction.site</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="sites_menu_item"
              name="Sites"
              parent="construction_menu"
              action="site_action"
              sequence="2"/>
</odoo>