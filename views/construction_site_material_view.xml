<odoo>
    <record id="site_material_view_tree" model="ir.ui.view">
        <field name="name">site material tree</field>
        <field name="model">construction.site.material</field>
        <field name="arch" type="xml">
            <tree>
                <field name="material_name"/>
                <field name="site_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="date"/>
                <field name="total_price"/>
            </tree>
        </field>
    </record>


    <record id="site_material_view_form" model="ir.ui.view">
        <field name="name">site material form</field>
        <field name="model">construction.site.material</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="material_name"/>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                        <field name="total_price"/>
                        <field name="date"/>
                        <field name="site_id"/>
                        <field name="note"/>

                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="site_material_action" model="ir.actions.act_window">
        <field name="name">Site Material</field>
        <field name="res_model">construction.site.material</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem
            id="site_material_menu_item"
            name="Materials per Site"
            parent="resources_menu"
            action="site_material_action"
            sequence="3"
    />
</odoo>