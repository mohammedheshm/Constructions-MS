<odoo>
    <record id="projects_view_tree" model="ir.ui.view">
        <field name="name">projects tree</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="project_name"/>
                <field name="project_code"/>
                <field name="customer"/>
                <field name="project_manager"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="budget"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="project_view_search" model="ir.ui.view">
        <field name="name">projects search</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="project_name"/>
                <field name="project_code"/>
                <field name="customer"/>
                <field name="project_manager"/>


                <filter name="state_draft"
                        string="Draft State"
                        domain="[('state','=','draft')]"/>

                <filter name="state_done"
                        string="Done State"
                        domain="[('state','=','done')]"/>

                <filter name="state_in_progress"
                        string="In Progress State"
                        domain="[('state','=','in_progress')]"/>


                <filter name="group_budget"
                        string="Group By budget"
                        context="{'group_by':'budget'}"/>

                <filter name="group_project_manager"
                        string="Group By Manager"
                        context="{'group_by':'project_manager'}"/>

                <filter name="group_state"
                        string="Group By State"
                        context="{'group_by':'state'}"/>

                <filter name="group_start_date"
                        string="Group By Start Date"
                        context="{'group_by':'start_date'}"/>

            </search>
        </field>
    </record>


    <record id="projects_view_form" model="ir.ui.view">
        <field name="name">projects form</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button name="action_draft"
                            type="object"
                            class="btn-primary"
                            string="Set To Draft"
                            invisible="state in ('draft','closed')"
                    />

                    <button name="action_in_progress"
                            type="object"
                            class="btn-secondary"
                            string="Set To Progress"
                            invisible="state != 'draft'"/>

                    <button name="action_done"
                            type="object"
                            class="btn-success"
                            string="Set To Done"
                            invisible="state != 'in_progress'"
                    />

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="project_code"/>
                        <h1>
                            <field name="project_code"/>
                        </h1>

                        <label for="project_name"/>
                        <h3>
                            <field name="project_name"/>
                        </h3>
                    </div>

                    <group>
                        <group string="Project Information">
                            <field name="customer"/>
                            <field name="project_manager"/>
                            <field name="workforce_ids" widget="many2many_tags" readonly="1"/>
                            <field name="site_ids" widget="many2many_tags" readonly="1"
                                   help="Sites can't be edited here. Use the 'Sites' tab below to add or edit Sites."/>
                        </group>

                        <group string="Project Dates">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group string="Financial Information">
                        <field name="budget"/>
                        <field name="expense_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Project Payment Summary" colspan="4">
                        <field name="contract_value"/>
                        <field name="total_paid" readonly="1" class="oe_highlight"/>
                        <field name="remaining_amount" readonly="1" class="oe_highlight"/>
                        <field name="remaining_status" readonly="1" class="oe_highlight"/>
                    </group>

                    <group string="Description">
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Sites">
                            <field name="site_ids">
                                <tree editable="bottom">
                                    <field name="site_name"/>
                                    <field name="location"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Expenses">
                            <field name="expense_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="expense_date"/>
                                    <field name="expense_type"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_material_cost"/>
                                <field name="workforce_cost"/>
                                <field name="total_expense"/>
                                <field name="total_project_cost"/>
                                <field name="net_profit"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="project_closed_server_action" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_construction_project"/>
        <field name="binding_model_id" ref="model_construction_project"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_close()
        </field>
    </record>


    <record id="projects_action" model="ir.actions.act_window">
        <field name="name">projects</field>
        <field name="res_model">construction.project</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem
            id="projects_menu_item"
            name="Projects"
            parent="construction_menu"
            action="projects_action"
            sequence="1"
    />

</odoo>