<odoo>

    <record id="module_category_construction" model="ir.module.category">
        <field name="name">Construction Management</field>
        <field name="description">Access control for construction system</field>
    </record>

    <record id="group_construction_user" model="res.groups">
        <field name="name">Construction User</field>
        <field name="category_id" ref="module_category_construction"/>
    </record>

    <record id="group_site_engineer" model="res.groups">
        <field name="name">Site Engineer</field>
        <field name="category_id" ref="module_category_construction"/>
    </record>

    <record id="group_accountant" model="res.groups">
        <field name="name">Accountant</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_user'))]"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Construction Manager</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[
        (4, ref('group_site_engineer')),
        (4, ref('group_accountant'))
    ]"/>
    </record>


</odoo>