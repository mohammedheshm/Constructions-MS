<odoo>
    <record id="expense_report" model="ir.actions.report">
        <field name="name">Expenses Report</field>
        <field name="model">construction.expense</field>
        <field name="report_type">qweb-html</field>
        <!--<field name="report_type">qweb-pdf</field>-->
        <field name="binding_model_id" ref="model_construction_expense"/>
        <field name="binding_type">report</field>
        <field name="report_name">construction_management_system.expense_report_template</field>
    </record>


    <template id="expense_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 style="text-align:center;">
                            Expenses Report
                        </h2>

                        <br/>

                        <table style="border-collapse: collapse; width:100%;">

                            <thead>

                                <tr>

                                    <th style="border:1px solid #000; padding:6px;">
                                        Expense Type
                                    </th>

                                    <th style="border:1px solid #000; padding:6px;">
                                        Project
                                    </th>

                                    <th style="border:1px solid #000; padding:6px;">
                                        Site
                                    </th>

                                    <th style="border:1px solid #000; padding:6px;">
                                        Date
                                    </th>

                                    <th style="border:1px solid #000; padding:6px;">
                                        Amount
                                    </th>

                                    <th style="border:1px solid #000; padding:6px;">
                                        Description
                                    </th>

                                </tr>

                            </thead>


                            <tbody>

                                <tr>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="o.expense_type"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="o.project_id"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="o.site_id"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="o.expense_date"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="o.amount"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="o.description"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>