<odoo>

    <record id="project_report" model="ir.actions.report">
        <field name="name">Project Report</field>
        <field name="model">construction.project</field>
        <field name="report_type">qweb-html</field>
        <!--<field name="report_type">qweb-pdf</field>-->
        <field name="binding_model_id" ref="model_construction_project"/>
        <field name="binding_type">report</field>
        <field name="report_name">construction_management_system.project_report_template</field>
    </record>


    <template id="project_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">

                    <div class="page">
                        <h2 style="text-align:center;">Project Report</h2>

                        <br/>

                        <h3>Project Information</h3>

                        <table class="table table-sm">

                            <tr>
                                <td>
                                    <strong>Project Name</strong>
                                </td>
                                <td>
                                    <span t-field="o.project_name"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Project Code</strong>
                                </td>
                                <td>
                                    <span t-field="o.project_code"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Customer</strong>
                                </td>
                                <td>
                                    <span t-field="o.customer"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Project Manager</strong>
                                </td>
                                <td>
                                    <span t-field="o.project_manager"/>
                                </td>
                            </tr>

                        </table>


                        <br/>
                        <h3>Sites</h3>

                        <table class="table table-sm" style="border-collapse: collapse; width:100%;">

                            <thead>
                                <tr>
                                    <th style="border:1px solid black;">Site Name</th>
                                    <th style="border:1px solid black;">Start Date</th>
                                    <th style="border:1px solid black;">End Date</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr t-foreach="o.site_ids" t-as="site">

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="site.site_name"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="site.start_date"/>
                                    </td>

                                    <td style="border:1px solid #000; padding:6px;">
                                        <span t-field="site.end_date"/>
                                    </td>

                                </tr>
                            </tbody>

                        </table>



                        <br/>

                        <h3>Financial Summary</h3>

                        <table class="table table-sm">

                            <tr>
                                <td>
                                    <strong>Total Expenses</strong>
                                </td>
                                <td>
                                    <span t-field="o.total_project_cost"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Total Invoices</strong>
                                </td>
                                <td>
                                    <span t-field="o.total_paid"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Profit / Loss</strong>
                                </td>
                                <td>
                                    <span t-field="o.net_profit"/>
                                </td>
                            </tr>

                        </table>

                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>